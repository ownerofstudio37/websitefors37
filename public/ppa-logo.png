			googletag.pubads().addEventListener('slotRenderEnded', function (event) {
				if (event.isEmpty) {
					//grab teh id of this slot
					const slotId = event.slot.getSlotElementId();
					//Is this in a swiperJs? We want to remove the slide so it fixes the layout
					if ($('#' + slotId).closest('.swiper-slide').length) {
						const $slide = $('#' + slotId).closest('.swiper-slide'); // or any .swiper-slide jQuery object

						const swiperEl = $slide.closest('.swiper')[0];
						const swiper = swiperEl?.swiper;
						const index = swiper.slides.indexOf($slide[0]);
						// If loop is enabled, rebuild the loop
						if (swiper.params.loop) {
							swiper.loopDestroy();
							swiper.removeSlide(index);
							swiper.loopCreate();
							swiper.update();
						} else {
							swiper.removeSlide(index);
							swiper.update();
						}
					}
