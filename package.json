{
  "name": "studio37-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:errors": "next lint --quiet",
    "typecheck": "tsc --noEmit",
    "test:smoke": "playwright test",
    "test:sitemap": "node scripts/validate-sitemap-endpoints.mjs",
    "audit:seo-assets": "node scripts/audit-public-seo-assets.mjs",
    "audit:service-schema": "node scripts/audit-service-page-schema.mjs",
    "audit:cloudinary-images": "node scripts/audit-cloudinary-image-quality.mjs",
    "audit:public-links": "node scripts/audit-public-links.mjs",
    "audit:route-metadata": "node scripts/audit-route-metadata.mjs",
    "audit:headers": "node scripts/audit-response-headers.mjs",
    "audit:fixed-ui": "node scripts/audit-fixed-ui-overlap.mjs",
    "audit:technical": "npm run audit:cloudinary-images && npm run audit:public-links && npm run audit:route-metadata && npm run audit:service-schema && npm run audit:headers && npm run audit:fixed-ui",
    "verify:seo": "node scripts/verify-production-seo.mjs",
    "repo:dev": "turbo run dev --parallel",
    "repo:build": "turbo run build",
    "repo:lint": "turbo run lint",
    "repo:typecheck": "turbo run typecheck",
    "web:dev": "turbo run dev --filter=web",
    "workflow:dev": "turbo run dev --filter=workflow",
    "import:training": "tsx scripts/import-website-content.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@react-email/components": "^0.0.25",
    "@react-email/render": "^1.4.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "googleapis": "^132.0.0",
    "resend": "^4.0.1",
    "twilio": "^5.3.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "turbo": "^1.11.2"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions",
    "not dead"
  ]
}
